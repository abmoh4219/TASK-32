DATABASE_URL=sqlite:///app/data/scholarvault.db
# ENCRYPTION_KEY and SIGNING_KEY MUST be random values of at least 32 bytes.
# The docker-compose `setup` service auto-generates fresh random values on
# first run. Never commit real secrets to this file or reuse these placeholders.
ENCRYPTION_KEY=REPLACE_ME_WITH_A_RANDOM_VALUE_AT_LEAST_32_BYTES_LONG
SIGNING_KEY=REPLACE_ME_WITH_A_RANDOM_VALUE_AT_LEAST_32_BYTES_LONG
RUST_LOG=info
HOST=0.0.0.0
PORT=3000
# Set COOKIE_SECURE=true in production (TLS-terminated) deployments so session
# and CSRF cookies are only sent over HTTPS. Leave false for local HTTP dev.
COOKIE_SECURE=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETAIN_DAILY=30
BACKUP_RETAIN_MONTHLY=12
