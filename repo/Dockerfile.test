# ScholarVault test runner — runs the 4 cargo test suites via run_tests.sh
# syntax=docker/dockerfile:1
FROM rust:slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev ca-certificates sqlite3 \
    && rm -rf /var/lib/apt/lists/*

RUN rustup component add llvm-tools-preview

ENV CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse
ENV SQLX_OFFLINE=true
ENV CARGO_TERM_COLOR=always

# Install cargo-tarpaulin BEFORE copying source so this expensive layer stays
# cached in Docker even when source files change.  Use a BuildKit cache for the
# cargo registry during the install so we download fewer bytes on rebuilds.
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    cargo install cargo-tarpaulin --locked

WORKDIR /workspace

COPY Cargo.toml Cargo.lock* ./
COPY shared ./shared
COPY backend ./backend
COPY frontend ./frontend
COPY run_tests.sh ./run_tests.sh

RUN chmod +x run_tests.sh

# Pre-fetch all workspace dependencies into the image layer (NOT a cache mount)
# so that docker run containers find the registry without network access.
RUN cargo fetch

CMD ["sh", "run_tests.sh"]
