# ScholarVault test runner — runs the 4 cargo test suites via run_tests.sh
FROM rust:slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev ca-certificates sqlite3 \
    && rm -rf /var/lib/apt/lists/*

# Add LLVM tools (required by cargo-tarpaulin --engine llvm)
RUN rustup component add llvm-tools-preview

WORKDIR /workspace

COPY Cargo.toml Cargo.lock* ./
COPY shared ./shared
COPY backend ./backend
COPY frontend ./frontend
COPY run_tests.sh ./run_tests.sh

ENV SQLX_OFFLINE=true
ENV CARGO_TERM_COLOR=always

RUN chmod +x run_tests.sh
RUN cargo fetch

# Install cargo-tarpaulin for code coverage (compiled once, cached in image layer)
RUN cargo install cargo-tarpaulin --locked

CMD ["sh", "run_tests.sh"]
